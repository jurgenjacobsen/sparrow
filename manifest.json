{
  "manifest_version": 3,
  "name": "Sparrow",
  "version": "1.0.0",
  "description": "A sleek Google Chrome extension for managing reminders",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "action": {
    "default_title": "Sparrow",
    "default_popup": "popup.html",
    "default_icon": "assets/icon.png"
  }
}